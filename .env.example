# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored — NEVER commit real keys.

# --- Gmail SMTP (for the daily email digest) ---
# Generate an App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Gemini API (for grading job offers) ---
# Free key: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=
GEMINI_PROJECT_ID=

# --- Optional: SerpAPI (Google Jobs source) ---
SERPAPI_KEY=

# --- Optional: LinkedIn cookies (logged-in scraping) ---
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
